@startuml Monopoly Deal - Standard Full Sequence Diagram
skinparam backgroundColor #FAFAFA
skinparam sequence {
    ArrowColor #222222
    ActorBorderColor #333333
    ParticipantBorderColor #333333
    LifeLineBorderColor #555555
}
hide footbox

actor Player as P
actor TargetPlayer as T
participant GameSystem as GS
participant DrawPile as DP
participant DiscardPile as DC
participant Bank as B
participant PropertyArea as PA

' ==============================
' 1. GAME INITIALIZATION (ORDERED)
' ==============================
P -> GS: Select number of players (2-5)
P -> GS: Select human or AI opponents
P -> GS: Select turn order
GS -> DP: Initialize draw pile
GS -> DC: Initialize discard pile
GS -> DP: Shuffle all cards
GS -> DP: Deal 5 cards to every player
GS --> P: Game starts successfully

' ==============================
' 2. TURN START (TIME SEQUENCE)
' ==============================
GS -> GS: Start current player turn
GS -> GS: Check hand card count

alt Hand > 0
    GS -> DP: Draw 2 cards
else Hand == 0
    GS -> DP: Draw 5 cards
end

alt Draw pile is empty
    GS -> DC: Shuffle discard pile to new draw pile
    DC --> DP: Refill draw pile
end

DP --> GS: Send cards
GS --> P: Add cards to hand

' ==============================
' 3. PLAYER ACTION PHASE (ALL OPTIONS)
' ==============================
P -> GS: Choose to play cards

alt Play card to Bank
    GS -> B: Move card to player bank
    GS -> GS: Update bank value
end

alt Play Property Card
    GS -> PA: Place property into color group
    GS -> PA: Update property set progress
end

alt Play Action Card
    P -> GS: Select action card to play

    ' === RENT ===
    alt Action = Rent
        GS -> T: Display rent amount
        loop Until rent fully paid
            T -> GS: Pay using bank or property
            GS -> GS: Calculate remaining rent
        end
        GS -> B: Transfer assets to Player
        GS -> DC: Discard Rent card
    end

    ' === DEAL BREAKER ===
    alt Action = Deal Breaker
        GS -> T: Check if Just Say No exists
        alt Target uses Just Say No
            GS -> DC: Discard Just Say No
            GS --> P: Action cancelled
        else
            GS -> PA: Move full property set to Player
            GS -> DC: Discard Deal Breaker
        end
    end

    ' === FORCE DEAL ===
    alt Action = Force Deal
        GS -> T: Check Just Say No
        alt Target resists
            GS --> P: Action cancelled
        else
            GS -> PA: Swap properties
        end
        GS -> DC: Discard Force Deal
    end

    ' === SLY DEAL ===
    alt Action = Sly Deal
        GS -> T: Check Just Say No
        alt Target resists
            GS --> P: Action cancelled
        else
            GS -> PA: Steal one property card
        end
        GS -> DC: Discard Sly Deal
    end

    ' === IT'S MY BIRTHDAY ===
    alt Action = Birthday
        GS -> A: All Players: Collect 2M from each
        GS -> B: Add money to Player bank
        GS -> DC: Discard Birthday card
    end

    ' === DEBT COLLECTOR ===
    alt Action = Debt Collector
        GS -> T: Request 5M payment
        loop Until full payment
            T -> GS: Pay with assets
        end
        GS -> B: Transfer 5M to Player
        GS -> DC: Discard Debt Collector
    end

    ' === HOUSE / HOTEL ===
    alt Action = House/Hotel
        GS -> PA: Add building to full property set
        GS -> PA: Update rent value
        GS -> DC: Discard building card
    end

    ' === JUST SAY NO ===
    alt Action = Just Say No
        GS --> T: Cancel opponent's action
        GS -> DC: Discard Just Say No
    end

end

' ==============================
' 4. END TURN
' ==============================
P -> GS: End turn
GS -> GS: Check hand size > 7
alt Hand > 7
    P -> GS: Discard cards to 7
    GS -> DC: Move discarded cards
end

' ==============================
' 5. WIN CONDITION CHECK
' ==============================
GS -> PA: Count full property sets
alt Full sets >= 3
    GS --> P: You win the game
    GS -> GS: Terminate game
else
    GS -> GS: Switch to next player
end

@enduml