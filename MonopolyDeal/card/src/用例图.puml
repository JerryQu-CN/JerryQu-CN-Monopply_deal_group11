@startuml Monopoly Deal Card Game - Full Use Case Diagram
' Global style configuration (optional, for better visualization)
left to right direction
skinparam usecase {
  BackgroundColor #e6f7ff
  BorderColor #2e86ab
}
skinparam actor {
  BorderColor #2c3e50
  BackgroundColor #f0f8ff
}
skinparam package {
  BackgroundColor #f9f9f9
  BorderColor #333333
}
skinparam arrow {
  LineColor #444444
}

' ====================== 1. Define Actors ======================
actor "Player" as P
actor "Robot AI" as R
actor "Game System" as GS

' ====================== 2. Define Top-Level Use Case Packages (By Requirement Module) ======================
package "Game Initialization" {
  usecase "Select Number of Players (2-5)" as UC1
  usecase "Select Opponent Type (Human/Robot)" as UC2
  usecase "Select Turn Order" as UC3
  usecase "Deal Initial Hand (5 Cards per Player)" as UC4
  usecase "Initialize Draw Pile & Discard Pile" as UC5
  usecase "Auto-Shuffle When Draw Pile Empty" as UC6
}

package "Turn Flow Management" {
  usecase "Auto-Draw at Turn Start" as UC7
  usecase "Draw 2 Cards (Hand > 0)" as UC8
  usecase "Draw 5 Cards (Hand = 0)" as UC9
  usecase "Play Cards (0-3 Cards)" as UC10
  usecase "End Turn" as UC11
  usecase "Check Hand Size (Discard if >7)" as UC12
  usecase "Move Discarded Cards to Discard Pile" as UC13
  usecase "Switch to Next Player's Turn" as UC14
}

package "Card Play Type Management" {
  usecase "Deposit to Bank (Cash/Action Cards)" as UC15
  usecase "Place Property Cards" as UC16
  usecase "Play Action Cards" as UC17
  usecase "Pay Rent" as UC18
}

package "Action Card System" {
  usecase "Use Rent to Collect Rent" as UC19
  usecase "Use Deal Breaker to Steal Full Property Set" as UC20
  usecase "Use Force Deal to Swap Properties" as UC21
  usecase "Use Sly Deal to Steal Single Property" as UC22
  usecase "Use It's My Birthday to Collect 2M" as UC23
  usecase "Use Debt Collector to Collect 5M" as UC24
  usecase "Use Just Say No to Cancel Actions" as UC25
  usecase "Add House/Hotel" as UC26
}

package "Win Condition Check" {
  usecase "Check for 3 Complete Property Sets" as UC27
  usecase "Announce Game Victory" as UC28
}

package "User Interface & Interaction" {
  usecase "Show Card Details (Hover/Click)" as UC29
  usecase "Display All Players' Assets" as UC30
  usecase "Show Hand Count" as UC31
  usecase "Zone-Based UI Layout" as UC32
}

