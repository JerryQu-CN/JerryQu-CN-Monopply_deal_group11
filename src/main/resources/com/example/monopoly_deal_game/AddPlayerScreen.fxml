<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="850.0" prefWidth="1400.0"
           styleClass="start-root"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.monopoly_deal_game.controller.AddPlayerScreenController">

    <!-- Background image -->
    <ImageView fitHeight="944.0" fitWidth="1400.0" pickOnBounds="true" preserveRatio="true"
               StackPane.alignment="CENTER">
        <Image url="@BackGround.png"/>
    </ImageView>

    <!-- Dark overlay -->
    <AnchorPane styleClass="start-overlay" StackPane.alignment="CENTER"/>

    <!-- Centered content -->
    <VBox alignment="CENTER" spacing="0" StackPane.alignment="CENTER">

        <Label text="Create Room" styleClass="lobby-title"/>

        <Region prefHeight="24"/>

        <!-- Glass-morphism content panel -->
        <VBox alignment="TOP_CENTER" spacing="14" styleClass="start-button-panel"
              maxWidth="700">

            <!-- Room info -->
            <Label fx:id="roomIdLabel" text="Room ID: --------"
                   styleClass="lobby-info-label"/>
            <Label fx:id="roomConnectionLabel"
                   text="Host IP: --------   Port: --------"
                   styleClass="lobby-info-label"/>

            <!-- Host nickname section -->
            <VBox alignment="TOP_LEFT" spacing="10" styleClass="lobby-section-panel">
                <Label text="Host Nickname" styleClass="lobby-input-label"/>
                <TextField fx:id="hostNameField" prefWidth="260.0"
                           promptText="Enter host nickname" styleClass="lobby-text-field"/>
            </VBox>

            <!-- Max players + create button -->
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label text="Max players (2-5)" styleClass="lobby-input-label"/>
                <ComboBox fx:id="maxPlayersCombo" prefWidth="120.0"
                          styleClass="lobby-combo-box"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="hostRoomButton" onAction="#onHostRoom"
                        prefHeight="42.0" prefWidth="160.0"
                        text="Create Room" styleClass="start-btn-primary"/>
            </HBox>

            <!-- Player list -->
            <Label text="Players in this room" styleClass="lobby-input-label"/>
            <ListView fx:id="joinedPlayersList" prefHeight="220.0" prefWidth="640.0"
                      styleClass="lobby-list-view"/>

            <!-- Action buttons -->
            <HBox alignment="CENTER" spacing="24">
                <Button fx:id="startGameButton" onAction="#onStartGame"
                        prefHeight="48.0" prefWidth="180.0"
                        text="Start Game" styleClass="start-btn-primary"/>
                <Button onAction="#onBack" prefHeight="48.0" prefWidth="120.0"
                        text="Back" styleClass="start-btn-secondary"/>
            </HBox>

            <!-- Status -->
            <Label fx:id="joinStatusLabel" text="" styleClass="lobby-status-label"/>
        </VBox>
    </VBox>
</StackPane>
