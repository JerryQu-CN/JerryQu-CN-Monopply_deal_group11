<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="850.0" prefWidth="1400.0"
           styleClass="start-root"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.monopoly_deal_game.controller.lobby.JoinRoomScreenController">

    <!-- Background image -->
    <ImageView fitHeight="944.0" fitWidth="1400.0" pickOnBounds="true" preserveRatio="true"
               StackPane.alignment="CENTER">
        <Image url="@BackGround.png"/>
    </ImageView>

    <!-- Dark overlay -->
    <AnchorPane styleClass="start-overlay" StackPane.alignment="CENTER"/>

    <!-- Centered content -->
    <VBox alignment="CENTER" spacing="0" StackPane.alignment="CENTER">

        <Label text="Join Room" styleClass="lobby-title"/>

        <Region prefHeight="24"/>

        <!-- Glass-morphism content panel -->
        <VBox alignment="TOP_CENTER" spacing="14" styleClass="start-button-panel"
              maxWidth="760">

            <Label fx:id="roomInfoLabel" text="Room info: --------"
                   styleClass="lobby-info-label"/>

            <!-- Nickname section -->
            <VBox alignment="TOP_LEFT" spacing="10" styleClass="lobby-section-panel">
                <Label text="Nickname" styleClass="lobby-input-label"/>
                <TextField fx:id="nicknameField" prefWidth="260.0"
                           promptText="Enter your nickname" styleClass="lobby-text-field"/>
            </VBox>

            <!-- Room address section -->
            <VBox alignment="TOP_LEFT" spacing="10" styleClass="lobby-section-panel">
                <Label text="Room Address" styleClass="lobby-input-label"/>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Room ID" styleClass="lobby-input-label"/>
                    <TextField fx:id="joinRoomField" prefWidth="140.0"
                               promptText="Room ID" styleClass="lobby-text-field"/>
                    <Label text="Host IP" styleClass="lobby-input-label"/>
                    <TextField fx:id="joinHostField" prefWidth="160.0"
                               promptText="Host IP" styleClass="lobby-text-field"/>
                    <Label text="Port" styleClass="lobby-input-label"/>
                    <TextField fx:id="joinPortField" prefWidth="110.0"
                               promptText="Port" styleClass="lobby-text-field"/>
                </HBox>
                <Label text="Enter the room ID, host address and port. Player limit is controlled by the host."
                       styleClass="lobby-helper-text"/>
            </VBox>

            <!-- Action buttons -->
            <HBox alignment="CENTER" spacing="18">
                <Button fx:id="joinButton" onAction="#onJoinRoom"
                        prefHeight="48.0" prefWidth="220.0"
                        text="Join Room" styleClass="start-btn-primary"/>
                <Button onAction="#onBack" prefHeight="48.0" prefWidth="220.0"
                        text="Back" styleClass="start-btn-secondary"/>
            </HBox>

            <!-- Status -->
            <Label fx:id="joinStatusLabel" text="" styleClass="lobby-status-label"/>

            <!-- Player list -->
            <Label text="Players in this room" styleClass="lobby-input-label"/>
            <ListView fx:id="joinedPlayersList" prefHeight="180.0" prefWidth="700.0"
                      styleClass="lobby-list-view"/>
        </VBox>
    </VBox>
</StackPane>
