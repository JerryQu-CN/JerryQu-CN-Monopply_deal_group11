<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.monopoly_deal_game.controller.GameplayScreenController"
           prefWidth="1400.0" prefHeight="850.0"
           styleClass="root-bg">

    <children>
        <AnchorPane fx:id="gameRoot" prefWidth="1400.0" prefHeight="850.0"
                    styleClass="root-pane">

            <children>
                <!-- Top bar -->
                <HBox fx:id="topbar"
                      alignment="CENTER_LEFT"
                      spacing="12.0"
                      styleClass="topbar"
                      AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0"
                      AnchorPane.topAnchor="0.0"
                      prefHeight="42.0">
                    <children>
                        <Button fx:id="menuButton" onAction="#onMenu" text="Menu"
                                styleClass="button-topbar"/>
                        <Button fx:id="debugButton" onAction="#onDebug" text="Debug"
                                styleClass="button-topbar"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="topbarTitle" text="Monopoly Deal -- Game"
                               styleClass="topbar-title" />
                    </children>
                </HBox>

                <!-- Left sidebar -->
                <VBox fx:id="leftSidebar"
                      focusTraversable="false"
                      spacing="10.0"
                      styleClass="sidebar-panel"
                      AnchorPane.leftAnchor="0.0"
                      AnchorPane.topAnchor="42.0"
                      AnchorPane.bottomAnchor="0.0"
                      prefWidth="196.0">

                    <children>
                        <Label text="Draw Pile" styleClass="sidebar-label"/>
                        <Pane fx:id="deckPane" prefHeight="118.0" focusTraversable="false"
                              styleClass="sidebar-deck-pane"/>
                        <Label text="Discard Pile" styleClass="sidebar-label"/>
                        <Pane fx:id="discardPane" prefHeight="96.0" focusTraversable="false"
                              styleClass="sidebar-deck-pane"/>
                        <Pane fx:id="voidPane" prefHeight="28.0"
                              styleClass="root-pane"/>

                        <Label fx:id="moneyHudLabel" wrapText="true" maxWidth="176.0"
                               text="Funds --"
                               styleClass="hud-money" />

                        <Label fx:id="movesLabel" text="Plays: --"
                               styleClass="moves-label"/>
                        <Label fx:id="feedbackLabel" wrapText="true" maxWidth="176.0"
                               text="" visible="false" managed="false"
                               styleClass="feedback-label" />

                        <Button fx:id="primaryActionButton" onAction="#onPrimaryAction" text="Action"
                                prefHeight="46.0" maxWidth="1.7976931348623157E308"
                                styleClass="button-primary"/>
                        <Button fx:id="undoButton" onAction="#onUndo" text="Undo (disabled)"
                                prefHeight="40.0" maxWidth="1.7976931348623157E308"
                                styleClass="button-secondary"/>

                        <Pane VBox.vgrow="ALWAYS" />
                        <Label fx:id="versionLabel" text="Version x.x.x"
                               styleClass="version-label" />
                    </children>
                </VBox>

                <!-- Opponents -->
                <Pane fx:id="opponentsPane" focusTraversable="false"
                      AnchorPane.leftAnchor="206.0"
                      AnchorPane.rightAnchor="280.0"
                      AnchorPane.topAnchor="54.0"
                      AnchorPane.bottomAnchor="220.0"
                      styleClass="table-panel" />

                <!-- Own board -->
                <Pane fx:id="selfBoardPane"
                      focusTraversable="false"
                      visible="false" managed="false"
                      AnchorPane.leftAnchor="206.0"
                      AnchorPane.rightAnchor="12.0"
                      AnchorPane.bottomAnchor="214.0"
                      prefHeight="0.0"
                      styleClass="root-pane" />

                <!-- Player Log -->
                <VBox fx:id="logPanel" spacing="0" focusTraversable="false"
                      styleClass="log-panel"
                      AnchorPane.rightAnchor="12.0"
                      AnchorPane.topAnchor="54.0"
                      AnchorPane.bottomAnchor="220.0"
                      prefWidth="256.0">
                    <children>
                        <Label text="Game Log"
                               styleClass="log-header"
                               maxWidth="Infinity" />
                        <ScrollPane fx:id="logScrollPane" fitToWidth="true"
                                    focusTraversable="false"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="scroll-pane-transparent"
                                    style="-fx-padding: 2;"
                                    VBox.vgrow="ALWAYS">
                            <VBox fx:id="logEntriesBox" spacing="1" focusTraversable="false"
                                  style="-fx-padding: 4 6 4 6;"
                                  fillWidth="true" />
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- Chat -->
                <Pane fx:id="chatPane"
                      focusTraversable="false"
                      visible="false" managed="false"
                      AnchorPane.topAnchor="52.0"
                      AnchorPane.rightAnchor="12.0"
                      prefWidth="260.0" prefHeight="200.0"
                      styleClass="table-panel" />

                <!-- Hand -->
                <Pane fx:id="handPane"
                      focusTraversable="false"
                      AnchorPane.leftAnchor="206.0"
                      AnchorPane.rightAnchor="12.0"
                      AnchorPane.bottomAnchor="12.0"
                      prefHeight="196.0"
                      styleClass="hand-panel" />

                <!-- Action overlay -->
                <Pane fx:id="actionLayer"
                      focusTraversable="false"
                      AnchorPane.leftAnchor="0.0"
                      AnchorPane.topAnchor="0.0"
                      AnchorPane.rightAnchor="0.0"
                      AnchorPane.bottomAnchor="0.0"
                      mouseTransparent="true"
                      pickOnBounds="false" />
            </children>
        </AnchorPane>

        <StackPane fx:id="menuOverlay"
                   visible="false" managed="false"
                   styleClass="menu-overlay">
            <children>
                <VBox alignment="CENTER" spacing="16.0"
                      styleClass="menu-dialog">
                    <children>
                        <Label text="Menu" styleClass="menu-dialog-title" />
                        <Label text="Menu / Leave"
                               styleClass="menu-dialog-subtitle" />
                        <Button fx:id="menuReturnButton" onAction="#onMenuReturn" text="Return to Game"
                                prefWidth="300.0" prefHeight="50.0" styleClass="button-primary"/>
                        <Button fx:id="menuLeaveButton" onAction="#onMenuLeave" text="Leave Game"
                                prefWidth="300.0" prefHeight="50.0" styleClass="button-secondary"/>
                    </children>
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                    </padding>
                </VBox>
            </children>
        </StackPane>

        <StackPane fx:id="gameOverOverlay"
                   visible="false" managed="false"
                   styleClass="game-over-overlay">
            <children>
                <VBox alignment="CENTER" spacing="20.0"
                      styleClass="game-over-banner">
                    <children>
                        <Label text="GAME OVER" styleClass="game-over-title" />
                        <Label fx:id="gameOverWinnerLabel" text=""
                               styleClass="game-over-winner" />
                        <Label fx:id="gameOverDetailLabel" text=""
                               styleClass="game-over-detail" />
                        <Region prefHeight="8" />
                        <Button fx:id="gameOverReturnButton"
                                onAction="#onGameOverReturn" text="Return to Menu"
                                prefWidth="300.0" prefHeight="50.0" styleClass="button-primary"/>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
