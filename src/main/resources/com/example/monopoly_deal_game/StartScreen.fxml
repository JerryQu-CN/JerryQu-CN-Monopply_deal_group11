<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>

<StackPane prefHeight="850.0" prefWidth="1400.0"
           styleClass="start-root"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.monopoly_deal_game.controller.StartScreenController">

    <!-- Background image -->
    <ImageView fitHeight="944.0" fitWidth="1400.0" pickOnBounds="true" preserveRatio="true"
               StackPane.alignment="CENTER">
        <Image url="@BackGround.png"/>
    </ImageView>

    <!-- Dark overlay for text readability -->
    <AnchorPane styleClass="start-overlay" StackPane.alignment="CENTER"/>

    <!-- Centered content -->
    <VBox alignment="CENTER" spacing="0" StackPane.alignment="CENTER">

        <!-- Hero / Title section -->
        <VBox alignment="CENTER" spacing="6" styleClass="start-hero">
            <Label text="MONOPOLY" styleClass="start-title-line1"/>
            <Label text="DEAL" styleClass="start-title-line2"/>
            <Region prefHeight="8"/>
            <Label text="Monopoly Deal Card Game" styleClass="start-subtitle"/>
        </VBox>

        <Region prefHeight="36"/>

        <!-- Button panel with glass-morphism effect -->
        <VBox alignment="CENTER" spacing="14" styleClass="start-button-panel">
            <Button fx:id="realPlayerButton" text="Create Room"
                    onAction="#onRealPlayer" styleClass="start-btn-primary"/>
            <Button fx:id="joinRoomButton" text="Join Room"
                    onAction="#onJoinRoom" styleClass="start-btn-secondary"/>
            <Button fx:id="exitButton" text="Exit"
                    onAction="#onExit" styleClass="start-btn-exit"/>
        </VBox>

        <Region prefHeight="20"/>

        <!-- Version -->
        <Label text="Monopoly Deal · v1.0" styleClass="start-version"/>
    </VBox>
</StackPane>
