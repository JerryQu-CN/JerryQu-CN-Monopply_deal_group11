<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:controller="com.example.monopoly_deal_game.controller.FirstRunScreenController"
           prefHeight="850.0" prefWidth="1400.0"
           styleClass="root-bg"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <AnchorPane fx:id="gameRoot" prefHeight="850.0" prefWidth="1400.0"
                    styleClass="root-pane">

            <children>
                <HBox fx:id="topbar" alignment="CENTER_LEFT" prefHeight="42.0" spacing="12.0"
                      styleClass="topbar"
                      AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Button fx:id="menuButton" onAction="#onMenu" text="Menu" styleClass="button-topbar"/>
                        <Button fx:id="debugButton" onAction="#onDebug" text="Debug" styleClass="button-topbar"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="topbarTitle"
                               styleClass="topbar-title"
                               text="Monopoly Deal / Compact"/>
                    </children>
                </HBox>

                <VBox fx:id="leftSidebar" prefWidth="196.0" spacing="10.0"
                      focusTraversable="false"
                      styleClass="sidebar-panel"
                      AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="42.0">

                    <children>
                        <Label text="Draw Pile" styleClass="sidebar-label"/>
                        <Pane fx:id="deckPane" prefHeight="180.0" focusTraversable="false"
                              styleClass="sidebar-deck-pane"/>
                        <Label text="Discard Pile" styleClass="sidebar-label"/>
                        <Pane fx:id="discardPane" prefHeight="168.0" focusTraversable="false"
                              styleClass="sidebar-deck-pane"/>
                        <Pane fx:id="voidPane" prefHeight="52.0" styleClass="root-pane"/>

                        <Label fx:id="moneyHudLabel" maxWidth="176.0"
                               styleClass="hud-money" text="Funds --" wrapText="true"/>

                        <Label fx:id="movesLabel" text="Plays: --" styleClass="moves-label"/>
                        <Label fx:id="feedbackLabel" maxWidth="176.0" styleClass="feedback-label"
                               text="" wrapText="true"/>
                        <Button fx:id="primaryActionButton" maxWidth="1.7976931348623157E308"
                                onAction="#onPrimaryAction" prefHeight="46.0" text="Action"
                                styleClass="button-primary"/>
                        <Button fx:id="undoButton" maxWidth="1.7976931348623157E308"
                                onAction="#onUndo" prefHeight="40.0" text="Undo (disabled)"
                                styleClass="button-secondary"/>

                        <Pane VBox.vgrow="ALWAYS"/>
                        <Label fx:id="versionLabel" styleClass="version-label" text="Version x.x.x"/>
                    </children>
                </VBox>

                <Pane fx:id="opponentsPane" focusTraversable="false"
                      styleClass="table-panel"
                      AnchorPane.bottomAnchor="466.0" AnchorPane.leftAnchor="206.0"
                      AnchorPane.rightAnchor="280.0" AnchorPane.topAnchor="54.0"/>

                <Pane fx:id="selfBoardPane" prefHeight="252.0"
                      focusTraversable="false"
                      styleClass="table-panel"
                      AnchorPane.bottomAnchor="216.0" AnchorPane.leftAnchor="206.0" AnchorPane.rightAnchor="280.0"/>

                <!-- Player Log -->
                <VBox fx:id="logPanel" spacing="0" focusTraversable="false"
                      styleClass="log-panel"
                      AnchorPane.rightAnchor="12.0"
                      AnchorPane.topAnchor="54.0"
                      AnchorPane.bottomAnchor="216.0"
                      prefWidth="256.0">
                    <children>
                        <Label text="Game Log"
                               styleClass="log-header"
                               maxWidth="Infinity" />
                        <ScrollPane fx:id="logScrollPane" fitToWidth="true"
                                    focusTraversable="false"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="scroll-pane-transparent"
                                    style="-fx-padding: 2;"
                                    VBox.vgrow="ALWAYS">
                            <VBox fx:id="logEntriesBox" spacing="1" focusTraversable="false"
                                  style="-fx-padding: 4 6 4 6;"
                                  fillWidth="true" />
                        </ScrollPane>
                    </children>
                </VBox>

                <Pane fx:id="handPane" prefHeight="196.0"
                      focusTraversable="false"
                      styleClass="hand-panel"
                      AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="206.0"
                      AnchorPane.rightAnchor="12.0"/>

                <Pane fx:id="actionLayer" focusTraversable="false"
                      mouseTransparent="true" pickOnBounds="false"
                      AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
            </children>
        </AnchorPane>

        <StackPane fx:id="menuOverlay" managed="false"
                   styleClass="menu-overlay" visible="false">
            <children>
                <VBox alignment="CENTER" spacing="16.0"
                      styleClass="menu-dialog">
                    <children>
                        <Label styleClass="menu-dialog-title" text="Menu"/>
                        <Label styleClass="menu-dialog-subtitle" text="Return or leave the current game"/>
                        <Button fx:id="menuReturnButton" onAction="#onMenuReturn" prefHeight="50.0" prefWidth="300.0"
                                styleClass="button-primary" text="Return to Game"/>
                        <Button fx:id="menuLeaveButton" onAction="#onMenuLeave" prefHeight="50.0" prefWidth="300.0"
                                styleClass="button-secondary" text="Leave Game"/>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </padding>
                </VBox>
            </children>
        </StackPane>

        <StackPane fx:id="gameOverOverlay" managed="false"
                   styleClass="game-over-overlay" visible="false">
            <children>
                <VBox alignment="CENTER" spacing="20.0"
                      styleClass="game-over-banner">
                    <children>
                        <Label styleClass="game-over-title" text="GAME OVER"/>
                        <Label fx:id="gameOverWinnerLabel" styleClass="game-over-winner" text=""/>
                        <Label fx:id="gameOverDetailLabel" styleClass="game-over-detail" text=""/>
                        <Region prefHeight="8"/>
                        <Button fx:id="gameOverReturnButton" onAction="#onGameOverReturn"
                                prefHeight="50.0" prefWidth="300.0"
                                styleClass="button-primary" text="Return to Menu"/>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
